{
  "$schema": "https://raw.githubusercontent.com/nicholasio/tauri-v2/main/tooling/cli/schema.json",
  "productName": "VoiceChat",
  "version": "0.1.0",
  "identifier": "com.voicechat.desktop",
  "build": {
    "frontendDist": "../../client",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "VoiceChat",
        "width": 400,
        "height": 700,
        "resizable": true,
        "decorations": true,
        "center": true,
        "url": "index.html"
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "VoiceChat"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": false
  }
}
